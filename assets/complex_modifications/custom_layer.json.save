  "title": "Custom Layer with Command Toggle and Caps Lock Remap",
  "rules": [
    {
      "description": "Remap Caps Lock to Command",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock"
          },
          "to": [
            {
              "key_code": "left_command"
            }
          ]
        }
      ]
    },
    {
      "description": "Map backslash/pipe key to delete on default layer",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "backslash"
          },
          "to": [
            {
              "key_code": "delete_forward"
            }
          ],
          "conditions": [
            {
              "type": "variable_unless",
              "name": "layer_mode",
              "value": 1
            }
          ]
        }
      ]
    },
    {
      "description": "Physical Command key as layer toggle",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_command"
          },
          "to": [
            {
              "set_variable": {
                "name": "layer_mode",
                "value": 1
              }
            }
          ],
          "to_after_key_up": [
            {
              "set_variable": {
                "name": "layer_mode",
                "value": 0
              }
            }
          ],
          "to_if_alone": [
            {
              "key_code": "left_command"
            }
          ]
        },
