---
interface Props {
  number: number;
  title: string;
  last?: boolean;
}

const { number, title, last = false } = Astro.props;
---

<div class="timeline-step">
  <div class="timeline-track">
    <div class="timeline-dot">
      <span>{number}</span>
    </div>
    {!last && <div class="timeline-line"></div>}
  </div>
  <div class="timeline-content glow-card">
    <h3>{title}</h3>
    <div class="timeline-body">
      <slot />
    </div>
  </div>
</div>

<style>
  .timeline-step {
    display: flex;
    gap: 1.5rem;
  }
  .timeline-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 40px;
  }
  .timeline-dot {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--text);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
    z-index: 1;
  }
  .timeline-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--text), var(--border));
    margin-top: 0;
  }
  .timeline-content {
    flex: 1;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }
  .timeline-content h3 {
    margin-bottom: 0.75rem;
  }
  .timeline-body {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
  }
  .timeline-body p {
    margin-bottom: 0.5rem;
  }
  .timeline-body ul {
    margin: 0.5rem 0;
    padding-left: 1.25rem;
  }
  .timeline-body li {
    margin-bottom: 0.3rem;
  }
  .timeline-body a {
    color: var(--accent);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .timeline-body a:hover {
    opacity: 0.8;
  }
  @media (max-width: 640px) {
    .timeline-step { gap: 1rem; }
    .timeline-track { width: 32px; }
    .timeline-dot { width: 30px; height: 30px; font-size: 0.8rem; }
  }
</style>
