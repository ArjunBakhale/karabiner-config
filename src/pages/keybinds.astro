---
import BaseLayout from '../layouts/BaseLayout.astro';
import KeybindTable from '../components/KeybindTable.astro';
---

<BaseLayout title="Keybinds - Hyper Key">
  <div class="page-header">
    <h1 class="animate-in">Keybinds</h1>
    <p class="page-desc animate-in delay-1">Every shortcut at a glance. Click a category to filter.</p>
  </div>

  <div class="filter-bar animate-in delay-2">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="hardware">Hardware</button>
    <button class="filter-btn" data-filter="nav">Navigation</button>
    <button class="filter-btn" data-filter="apps">Apps</button>
    <button class="filter-btn" data-filter="window">Windows</button>
    <button class="filter-btn" data-filter="system">System</button>
    <button class="filter-btn" data-filter="raycast">Raycast</button>
  </div>

  <div class="kb-grid">

    <KeybindTable title="Key Remappings" badge="Hardware" id="hardware">
      <tr>
        <td><kbd>Left Command</kbd> <small class="highlight">(hold)</small></td>
        <td>Hyper Key modifier</td>
      </tr>
      <tr>
        <td><kbd>Left Command</kbd> <small class="green">(tap)</small></td>
        <td>Raycast <span class="accent">(Opt+Space)</span></td>
      </tr>
      <tr>
        <td><kbd>Caps Lock</kbd></td>
        <td>Command</td>
      </tr>
      <tr>
        <td><kbd>Right Option</kbd></td>
        <td>Open Firefox</td>
      </tr>
      <tr>
        <td><kbd>Right Command</kbd></td>
        <td>Left Click</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Backslash" badge={"\\"}  id="hardware">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>\</kbd></td>
        <td>Backslash (passthrough)</td>
      </tr>
      <tr>
        <td><kbd>Shift</kbd><span class="plus">+</span><kbd>\</kbd></td>
        <td>Pipe (passthrough)</td>
      </tr>
      <tr>
        <td><kbd>Option</kbd><span class="plus">+</span><kbd>\</kbd></td>
        <td>Forward Delete Word</td>
      </tr>
      <tr>
        <td><kbd>Command</kbd><span class="plus">+</span><kbd>\</kbd></td>
        <td>Forward Delete to End of Line</td>
      </tr>
      <tr>
        <td><kbd>\</kbd> <small class="highlight">(alone)</small></td>
        <td>Forward Delete</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Hyper Root" badge="Base Layer" id="nav">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>E</kbd></td>
        <td>Escape</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>X</kbd></td>
        <td>Option (modifier)</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Z</kbd></td>
        <td>Control (modifier)</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>C</kbd></td>
        <td>Command (modifier)</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Space</kbd></td>
        <td><span class="accent">Cmd+Shift+Space</span></td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Vim Navigation" badge="H J K L" id="nav">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>H</kbd></td>
        <td>&larr; Left</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>J</kbd></td>
        <td>&darr; Down</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>K</kbd></td>
        <td>&uarr; Up</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>L</kbd></td>
        <td>&rarr; Right</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="App Launchers" badge="Quick Launch" id="apps">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>A</kbd></td>
        <td>Firefox</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>B</kbd></td>
        <td>Docker</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>F</kbd></td>
        <td>Ghostty</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>G</kbd></td>
        <td>Codex</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>I</kbd></td>
        <td>Granola</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>M</kbd></td>
        <td>Messages</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>N</kbd></td>
        <td><span class="accent">Option+M</span></td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>P</kbd></td>
        <td>Discord</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Q</kbd></td>
        <td>Slack</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>U</kbd></td>
        <td>Conductor</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>V</kbd></td>
        <td>VS Code</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>O</kbd></td>
        <td>ChatGPT</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>5</kbd></td>
        <td>Screen Recording</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>W</kbd></td>
        <td>Finder</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Y</kbd></td>
        <td>Spotify</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>;</kbd></td>
        <td>Raycast Notes</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>'</kbd></td>
        <td>Linear</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Display & Screenshots" badge="Numbers" id="system">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>1</kbd></td>
        <td>Previous Display</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>2</kbd></td>
        <td>Next Display</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>3</kbd></td>
        <td>Screenshot</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>4</kbd></td>
        <td>Screenshot Area</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Sublayer Activators" badge="Hold" id="nav">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>D</kbd> <small class="highlight">(hold)</small></td>
        <td>Window Mode</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>S</kbd> <small class="highlight">(hold)</small></td>
        <td>System Mode</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>R</kbd> <small class="highlight">(hold)</small></td>
        <td>Raycast Mode</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Window Mode" badge="Hyper + D" id="window">
      <tr>
        <td><kbd>H</kbd></td>
        <td>Left Half</td>
      </tr>
      <tr>
        <td><kbd>J</kbd></td>
        <td>Bottom Half</td>
      </tr>
      <tr>
        <td><kbd>K</kbd></td>
        <td>Top Half</td>
      </tr>
      <tr>
        <td><kbd>L</kbd></td>
        <td>Right Half</td>
      </tr>
      <tr>
        <td><kbd>Enter</kbd></td>
        <td>Maximize</td>
      </tr>
      <tr>
        <td><kbd>N</kbd></td>
        <td>Float</td>
      </tr>
      <tr>
        <td><kbd>B</kbd></td>
        <td>Show Desktop</td>
      </tr>
      <tr>
        <td><kbd>M</kbd></td>
        <td>Center</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="System Mode" badge="Hyper + S" id="system">
      <tr>
        <td><kbd>H</kbd></td>
        <td>Rewind (Previous Song)</td>
      </tr>
      <tr>
        <td><kbd>J</kbd></td>
        <td>Next Tab</td>
      </tr>
      <tr>
        <td><kbd>K</kbd></td>
        <td>Previous Tab</td>
      </tr>
      <tr>
        <td><kbd>P</kbd></td>
        <td>Play / Pause</td>
      </tr>
      <tr>
        <td><kbd>L</kbd></td>
        <td>Fast Forward (Next Song)</td>
      </tr>
      <tr>
        <td><kbd>T</kbd></td>
        <td>Toggle</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Raycast Mode" badge="Hyper + R" id="raycast">
      <tr>
        <td><kbd>N</kbd></td>
        <td>Notes</td>
      </tr>
      <tr>
        <td><kbd>E</kbd></td>
        <td>Emoji & Symbols</td>
      </tr>
      <tr>
        <td><kbd>P</kbd></td>
        <td>Confetti</td>
      </tr>
      <tr>
        <td><kbd>H</kbd></td>
        <td>Clipboard History</td>
      </tr>
    </KeybindTable>

  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 3rem 0 1.5rem;
  }
  .page-desc {
    color: var(--text-muted);
    font-size: 1rem;
    margin-top: 0.5rem;
  }
  .filter-bar {
    display: flex;
    gap: 0.35rem;
    padding-bottom: 1.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .filter-btn {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 0.4rem 1rem;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: all 0.15s;
  }
  .filter-btn:hover {
    border-color: var(--border-hover);
    color: var(--text);
  }
  .filter-btn.active {
    background: var(--text);
    color: white;
    border-color: var(--text);
  }
  .kb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    gap: 1rem;
    padding-bottom: 2rem;
  }

  @media (max-width: 500px) {
    .kb-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.kb-card');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.getAttribute('data-filter');

        cards.forEach(card => {
          const el = card as HTMLElement;
          if (filter === 'all' || el.dataset.category === filter) {
            el.style.display = '';
            el.style.animation = 'fadeUp 0.3s ease forwards';
          } else {
            el.style.display = 'none';
          }
        });
      });
    });
  });
</script>
