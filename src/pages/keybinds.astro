---
import BaseLayout from '../layouts/BaseLayout.astro';
import KeybindTable from '../components/KeybindTable.astro';
---

<BaseLayout title="Keybind Reference - Karabiner">
  <h1>Karabiner Keybinds</h1>
  <p class="subtitle">Hyper Key System &mdash; Left Command as Hyper</p>

  <div class="grid">

    <KeybindTable title="Key Remappings" badge="Hardware">
      <tr>
        <td><kbd>Left Command</kbd> <small class="highlight">(hold)</small></td>
        <td>Hyper Key modifier</td>
      </tr>
      <tr>
        <td><kbd>Left Command</kbd> <small class="green">(tap)</small></td>
        <td>Raycast <span class="accent">(Opt+Space)</span></td>
      </tr>
      <tr>
        <td><kbd>Caps Lock</kbd></td>
        <td>Command</td>
      </tr>
      <tr>
        <td><kbd>Right Option</kbd></td>
        <td>Open Firefox</td>
      </tr>
      <tr>
        <td><kbd>Right Command</kbd></td>
        <td>Left Click</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Backslash Remapping" badge={"\\"}>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>\</kbd></td>
        <td>Backslash (passthrough)</td>
      </tr>
      <tr>
        <td><kbd>Shift</kbd><span class="plus">+</span><kbd>\</kbd></td>
        <td>Pipe (passthrough)</td>
      </tr>
      <tr>
        <td><kbd>Option</kbd><span class="plus">+</span><kbd>\</kbd></td>
        <td>Forward Delete Word</td>
      </tr>
      <tr>
        <td><kbd>Command</kbd><span class="plus">+</span><kbd>\</kbd></td>
        <td>Forward Delete to End of Line</td>
      </tr>
      <tr>
        <td><kbd>\</kbd> <small class="highlight">(alone)</small></td>
        <td>Forward Delete</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Hyper Root" badge="No sublayer">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>E</kbd></td>
        <td>Escape</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>X</kbd></td>
        <td>Option (modifier)</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Z</kbd></td>
        <td>Control (modifier)</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>C</kbd></td>
        <td>Command (modifier)</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>V</kbd></td>
        <td>Open VS Code</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Tab</kbd></td>
        <td>Next Tab <span class="accent">(Ctrl+Tab)</span></td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Space</kbd></td>
        <td><span class="accent">Cmd+Shift+Space</span></td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Vim Navigation" badge="HJKL">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>H</kbd></td>
        <td>Left Arrow</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>J</kbd></td>
        <td>Down Arrow</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>K</kbd></td>
        <td>Up Arrow</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>L</kbd></td>
        <td>Right Arrow</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="App Launchers" badge="Hyper + Key">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>A</kbd></td>
        <td>Firefox</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>B</kbd></td>
        <td>Docker</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>F</kbd></td>
        <td>Ghostty</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>G</kbd></td>
        <td>GitHub Desktop</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>I</kbd></td>
        <td>Granola</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>M</kbd></td>
        <td>Messages</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>N</kbd></td>
        <td><span class="accent">Option+M</span></td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>P</kbd></td>
        <td>Discord</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Q</kbd></td>
        <td>Slack</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>U</kbd></td>
        <td>Codex</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>W</kbd></td>
        <td>Finder</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>Y</kbd></td>
        <td>Spotify</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>;</kbd></td>
        <td>Raycast Notes</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>'</kbd></td>
        <td>Linear</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Display & Screenshots" badge="Numbers">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>1</kbd></td>
        <td>Move to Previous Display</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>2</kbd></td>
        <td>Move to Next Display</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>3</kbd></td>
        <td>Screenshot <span class="accent">(Ctrl+Shift+Cmd+3)</span></td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>4</kbd></td>
        <td>Screenshot Area <span class="accent">(Ctrl+Shift+Cmd+4)</span></td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Sublayer Activators" badge="Hold">
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>D</kbd> <small class="highlight">(hold)</small></td>
        <td>Enter Window Mode</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>S</kbd> <small class="highlight">(hold)</small></td>
        <td>Enter System Mode</td>
      </tr>
      <tr>
        <td><kbd>Hyper</kbd><span class="plus">+</span><kbd>R</kbd> <small class="highlight">(hold)</small></td>
        <td>Enter Raycast Mode</td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Window Mode" badge="Hyper + D + ...">
      <tr>
        <td><kbd>H</kbd></td>
        <td>Left Half</td>
      </tr>
      <tr>
        <td><kbd>J</kbd></td>
        <td>Bottom Half</td>
      </tr>
      <tr>
        <td><kbd>K</kbd></td>
        <td>Top Half</td>
      </tr>
      <tr>
        <td><kbd>L</kbd></td>
        <td>Right Half</td>
      </tr>
      <tr>
        <td><kbd>Enter</kbd><span class="separator">/</span><kbd>F</kbd></td>
        <td>Maximize <span class="accent">(Ctrl+Opt+Enter)</span></td>
      </tr>
      <tr>
        <td><kbd>U</kbd></td>
        <td>Next Window <span class="accent">(Ctrl+Tab)</span></td>
      </tr>
      <tr>
        <td><kbd>I</kbd></td>
        <td>Previous Window <span class="accent">(Ctrl+Shift+Tab)</span></td>
      </tr>
      <tr>
        <td><kbd>N</kbd></td>
        <td>Float <span class="accent">(Ctrl+Opt+F)</span></td>
      </tr>
      <tr>
        <td><kbd>B</kbd></td>
        <td>Show Desktop <span class="accent">(Ctrl+Opt+D)</span></td>
      </tr>
      <tr>
        <td><kbd>M</kbd></td>
        <td>Center <span class="accent">(Ctrl+Opt+G)</span></td>
      </tr>
    </KeybindTable>

    <KeybindTable title="System Mode" badge="Hyper + S + ...">
      <tr>
        <td><kbd>J</kbd></td>
        <td>Next Space <span class="accent">(Ctrl+Tab)</span></td>
      </tr>
      <tr>
        <td><kbd>K</kbd></td>
        <td>Previous Space <span class="accent">(Ctrl+Shift+Tab)</span></td>
      </tr>
      <tr>
        <td><kbd>P</kbd></td>
        <td>Play / Pause</td>
      </tr>
      <tr>
        <td><kbd>;</kbd></td>
        <td>Fast Forward</td>
      </tr>
      <tr>
        <td><kbd>T</kbd></td>
        <td>Toggle <span class="accent">(Opt+Shift+D)</span></td>
      </tr>
      <tr>
        <td><kbd>D</kbd></td>
        <td>Back <span class="accent">(Cmd+[)</span></td>
      </tr>
      <tr>
        <td><kbd>F</kbd></td>
        <td>Forward <span class="accent">(Cmd+])</span></td>
      </tr>
    </KeybindTable>

    <KeybindTable title="Raycast Mode" badge="Hyper + R + ...">
      <tr>
        <td><kbd>1</kbd></td>
        <td>Connect Bluetooth Device 1</td>
      </tr>
      <tr>
        <td><kbd>2</kbd></td>
        <td>Connect Bluetooth Device 2</td>
      </tr>
      <tr>
        <td><kbd>N</kbd></td>
        <td>Raycast Notes</td>
      </tr>
      <tr>
        <td><kbd>E</kbd></td>
        <td>Search Emoji & Symbols</td>
      </tr>
      <tr>
        <td><kbd>P</kbd></td>
        <td>Confetti</td>
      </tr>
      <tr>
        <td><kbd>H</kbd></td>
        <td>Clipboard History</td>
      </tr>
    </KeybindTable>

  </div>
</BaseLayout>

<style>
  h1 { text-align: center; }
  .subtitle { text-align: center; }
</style>
